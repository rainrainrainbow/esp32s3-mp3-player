# ESP32-S3 N16R8 with OPI PSRAM sdkconfig
#
# Automatically generated by ESP-IDF. DO NOT EDIT
#
CONFIG_IDF_TARGET="esp32s3"
CONFIG_IDF_TARGET_ESP32S3=y
CONFIG_IDF_FIRMWARE_CHIP_ID=0x0009

# FreeRTOS
CONFIG_FREERTOS_HZ=1000
CONFIG_FREERTOS_NUMBER_OF_CORES=2
CONFIG_FREERTOS_TASK_FUNCTION_WRAPPER=y

# Compiler optimizations
CONFIG_OPTIMIZATION_LEVEL_RELEASE=y
CONFIG_COMPILER_OPTIMIZATION_PERF=y

# Flash
CONFIG_ESPTOOLPY_FLASHSIZE_16MB=y
CONFIG_ESPTOOLPY_FLASHSIZE="16MB"
CONFIG_ESPTOOLPY_FLASHMODE_QIO=y
CONFIG_ESPTOOLPY_FLASHFREQ_80M=y
CONFIG_ESPTOOLPY_FLASHFREQ="80m"

# Partition Table
CONFIG_PARTITION_TABLE_CUSTOM=y
CONFIG_PARTITION_TABLE_CUSTOM_FILENAME="partitions.csv"
CONFIG_PARTITION_TABLE_FILENAME="partitions.csv"

# PSRAM (OPI)
CONFIG_SPIRAM=y
CONFIG_SPIRAM_TYPE_ESP32S3=y
CONFIG_SPIRAM_MODE_OCT=y
CONFIG_SPIRAM_SPEED_80M=y
CONFIG_SPIRAM_IGNORE_NOTFOUND=y
CONFIG_SPIRAM_USE_CAPS_ALLOC=y
CONFIG_SPIRAM_CACHE_WORKAROUND=y

# ESP32-S3 specific
CONFIG_ESP32S3_DEFAULT_CPU_FREQ_240=y
CONFIG_ESP32S3_DATA_CACHE_64KB=y
CONFIG_ESP32S3_INSTRUCTION_CACHE_32KB=y

# WiFi/Bluetooth (disable for audio player)
CONFIG_BT_ENABLED=n
CONFIG_BT_BLUEDROID_ENABLED=n
CONFIG_SW_COEXIST_ENABLE=n

# I2C
CONFIG_I2C_MASTER_SCL_DISABLE_IN_ACTIVE=y

# Audio - I2S
CONFIG_I2S_SUPPORTS_PDM_TX=n
CONFIG_I2S_SUPPORTS_PDM_RX=n
CONFIG_I2S_SUPPORTS_TDM=n

# FATFS
CONFIG_FATFS_VOLUME_COUNT=2
CONFIG_FATFS_LFN_STACK=y
CONFIG_FATFS_MAX_LFN=255

# Wear Levelling
CONFIG_WL_SECTOR_SIZE=4096
CONFIG_WL_SECTOR_MODE_SAFE=y

# TinyUSB

# Heap
CONFIG_HEAP_POISONING_DISABLED=y
CONFIG_SPIRAM_ALLOW_STACK_EXTERNAL_MEMORY=y

# Logging
CONFIG_LOG_MAXIMUM_LEVEL=INFO
CONFIG_LOG_TIMESTAMP_SOURCE_RTOS=y

# LWIP - disable unused
CONFIG_LWIP_DHCP=n
CONFIG_LWIP_DNS=n
CONFIG_LWIP_NETIF_LOOPBACK=n

# Newlib
CONFIG_NEWLIB_NANO_FORMAT=y

# Main task
CONFIG_ESP_MAIN_TASK_STACK_SIZE=8192

# Console
CONFIG_ESP_CONSOLE_UART_DEFAULT=y
CONFIG_ESP_CONSOLE_MULTIPLE_UART=y

# Compiler
CONFIG_COMPILER_CXX_EXCEPTIONS=n
CONFIG_COMPILER_CXX_RTTI=n